# Server Configuration
NODE_ENV=production
PORT=3000
ENABLE_CLUSTERING=true

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clawtrial
DB_USER=clawtrial
DB_PASSWORD=your_secure_password
DB_SSL=false
DB_POOL_MAX=50
DB_POOL_MIN=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
ALLOWED_ORIGINS=https://clawtrial.com,https://www.clawtrial.com
LOG_LEVEL=info

# API Keys (for admin endpoints)
ADMIN_API_KEY=your_admin_key_here
